Vauchi/Generated/
Vauchi/Libs/
Frameworks/

# Local-bindings workspace (created by `just bindings-local`)
Vauchi.xcworkspace/

# CocoaPods (if used)
Pods/

# Carthage (if used)
Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

