# SwiftFormat configuration — aligned with SwiftLint defaults

# Disable trailing commas to match SwiftLint trailing_comma rule
--trailingcommas never

# Disable wrapMultilineStatementBraces to match SwiftLint opening_brace rule
--disable wrapMultilineStatementBraces
